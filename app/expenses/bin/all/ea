#!/bin/sh

lib .

_expenses_get_all() {
	_expenses_header

	local field
	for field in $(printf '%s' "$_CONF_EXPENSES_TEXT_FIELDS" | tr '|' '\n'); do
		_expenses_get $field
	done

	_expenses_price

	printf '%s\n' "$_RECORD" >>$_EXPENSES_FILE
}

_expenses_header() {
	[ -e $_EXPENSES_FILE ] && return 1
	printf '%s\n' "$_CONF_EXPENSES_TEXT_FIELDS|$_CONF_EXPENSES_NUMERICAL_FIELDS" >$_EXPENSES_FILE
}

_expenses_get() {
	_read_if "Enter $1" _value

	if [ -n "$_RECORD" ]; then
		_RECORD="$_RECORD|$_value"
	else
		_RECORD="$_value"
	fi

	unset _value
}

_expenses_price() {
	local numerical_field
	local index=0
	for numerical_field in $(printf '%s' "$_CONF_EXPENSES_NUMERICAL_FIELDS" | tr '|' '\n'); do
		_read_if "Enter $numerical_field:" COST${index}
		index=$(($index + 1))
	done

	[ -z "$COST2" ] && COST2=0
	[ -z "$COST3" ] && COST3=0
	[ -z "$COST4" ] && COST4=0
	[ -z "$COST5" ] && COST5=$(printf '%s' "$COST0*$COST1+$COST2+$COST3+$COST4" | bc)

	_RECORD="$_RECORD|$COST0|$COST1|$COST2|$COST3|$COST4|$COST5"
}

_expenses_set_filename "$@" && shift

_expenses_get_all

_INFO "recorded expense @ $_EXPENSES_FILE"
