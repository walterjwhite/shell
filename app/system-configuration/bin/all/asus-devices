#!/bin/sh

if [ $# -lt 1 ]; then
	_ERROR "Unique device identifier is required (Asus Router IP)"
fi

_ASUS_ROUTER_IP=$1
shift

_asus_device_activity() {
	if [ ! -e /var/log/messages ]; then
		return 1
	fi

	local devices=$(grep $_ASUS_ROUTER_IP /var/log/messages/log |
		$_CONF_GNU_GREP -Poi '[0-9a-f]{2}:[0-9a-f]{2}:[0-9a-f]{2}:[0-9a-f]{2}:[0-9a-f]{2}:[0-9a-f]{2}' |
		tr '[:lower:]' '[:upper:]' | sort -u)

	local device
	for device in $devices; do
		grep $_ASUS_ROUTER_IP /var/log/messages/log |
			grep -i $device
	done
}

_asus_device_activity
