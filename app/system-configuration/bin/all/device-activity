#!/bin/sh

if [ $# -lt 1 ]; then
	_ERROR "Unique device identifier is required (IP, MAC)"
fi

_DEVICE_ID=$1
shift

_DEVICE_ID=$(printf '%s\n' "$_DEVICE_ID" | tr '[:upper:]' '[:lower:]')

_device() {
	local type
	printf $_DEVICE_ID | $_CONF_GNU_GREP -iPcs '[0-9a-f]{2}\:[0-9a-f]{2}\:[0-9a-f]{2}\:[0-9a-f]{2}\:[0-9a-f]{2}\:[0-9a-f]{2}' >/dev/null 2>&1 && {
		type=mac
		_DEVICE_ID=$(printf '%s\n' "$_DEVICE_ID" | tr ':' '.')
	}

	printf $_DEVICE_ID | $_CONF_GNU_GREP -iPcs '[0-9a-f]{2}\.[0-9a-f]{2}\.[0-9a-f]{2}\.[0-9a-f]{2}\.[0-9a-f]{2}\.[0-9a-f]{2}' >/dev/null 2>&1 && type=mac

	if [ -z "$mac" ]; then
		_DEVICE_ID=$(grep $_DEVICE_ID /etc/ethers | awk {'print$1'} | tr ':' '.')
	fi

	_DEVICE_CONF=$(find /usr/local/etc/walterjwhite/system-configuration/devices -type f -name $_DEVICE_ID ! -name '.*')
	_DEVICE_IP=$(grep IP= $_DEVICE_CONF | sed -e 's/^IP=//')
	_DEVICE_HOSTNAME=$(grep HOSTNAME= $_DEVICE_CONF | sed -e 's/^HOSTNAME=//')

	_INFO "Activity for: $_DEVICE_ID | $_DEVICE_CONF | $_DEVICE_HOSTNAME | $_DEVICE_IP"
}

_wifi_activity() {
	if [ ! -e /var/log/messages ]; then
		return 1
	fi

	{
		cat /var/log/messages/log
		zstdcat /var/log/messages/log*.zst
	} | awk /$_DEVICE_ID/ | awk '{print$1" "$2" "$3" " $9" "$5" "$7}' | sed -e 's/:$//' |
		less
}

_isc_dhcpd_activity() {
	if [ ! -e /var/log/dhcpd ]; then
		return 1
	fi

	{
		cat /var/log/dhcpd/log
		zstdcat /var/log/dhcpd/log*.zst
	} | awk /$_DEVICE_ID/ | awk '{print$1" "$2" "$3" " $7" "$9" "$11}' |
		sed -e 's/DHCPACK/ACK/g' -e 's/DHCPREQUEST/REQ/g' -e 's/DHCPDISCOVER/DIS/g' -e 's/DHCPOFFER/OFF/g' |
		less
}

_dnsmasq_activity() {
	if [ ! -e /var/log/dnsmasq ]; then
		return 1
	fi

	{
		cat /var/log/dnsmasq/log
		zstdcat /var/log/dnsmasq/log*.zst
	} | awk /$_DEVICE_ID/ | awk '{print$1" "$2" "$3" " $6" "$7" "$8}' | grep DHCP |
		sed -e 's/DHCPACK/ACK/g' -e 's/DHCPREQUEST/REQ/g' -e 's/DHCPDISCOVER/DIS/g' -e 's/DHCPOFFER/OFF/g' | less

	local ip=$(cat /var/log/dnsmasq/log | awk /$_DEVICE_ID/ | awk {'print$7'} | head -1)
	if [ -z "$ip" ]; then
		ip=$(zstdcat /var/log/dnsmasq/log*.zst | awk /$_DEVICE_ID/ | awk {'print$7'} | head -1)
	fi

	{
		cat /var/log/dnsmasq/log
		zstdcat /var/log/dnsmasq/log*.zst
	} | awk /$ip/ | grep -v DHCP | awk '{print$1" "$2" "$3" " $5" "$6}' | less
}

_device
_wifi_activity
_isc_dhcpd_activity
_dnsmasq_activity
