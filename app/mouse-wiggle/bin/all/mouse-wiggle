#!/bin/sh

lib graphics
lib ./wiggle.sh

${_CONF_MOUSE_WIGGLE_UI_BACKEND}_init
${_CONF_MOUSE_WIGGLE_UI_AUTOMATION_PROVIDER}_init

_require "$SCREEN_WIDTH" SCREEN_WIDTH
_require "$SCREEN_HEIGHT" SCREEN_HEIGHT

_DETAIL "detected screen resolution of: $SCREEN_WIDTH x $SCREEN_HEIGHT"
_DETAIL "sleeping before wiggling: $_CONF_MOUSE_WIGGLE_INIT_WAIT"
sleep $_CONF_MOUSE_WIGGLE_INIT_WAIT

_increase_indent
while [ -z "$_EXIT" ]; do
	_wiggle
done
