#!/bin/sh

readonly REQUIRED_ARGUMENTS="_DATE_NAME:Date Name"

lib sudo.sh

sudo_ensure_root "$@"

_ELEMENTS=$(printf '%s' $_DATE_NAME | tr '/' '\n' | wc -l | awk {'print$1'})
if [ $_ELEMENTS -ne 3 ]; then
  exit_with_error "date / Name is in an invalid format: $_DATE_NAME ($_ELEMENTS) - should be: 2021-2030/2025/01.January/15.0.snow-forts" 2
fi

_move() {
  _SOURCE=$conf_media_mountpoint/DCIM
  if [ ! -e $_SOURCE ]; then
    _unmount
    exit_with_error "$_SOURCE does not exist" 5
  fi

  _TARGET=$_STAGING_AREA/$_DATE_NAME
  mkdir -p $(dirname _TARGET)

  mv $_SOURCE $_TARGET

  chown -R $conf_media_user:$conf_media_user $_TARGET
}

_mount
_move
_unmount
