#!/bin/sh


cd /media/output

_media_find_links() {
  find /media/output/by-time /media/output/by-tag -type l | sort >$_FILE
}

_media_find_unique_filenames() {
  cat $_FILE | xargs basename | sort -u >$_FILE.unique
}

_media_map() {
  while read filename; do
    _matched_files=$($GNU_GREP -P "/${filename}$" $_FILE | $GNU_GREP -Pv '/(selected|print|by-tag)/' | sort)
    if [ $(printf '%s\n' "$_matched_files" | wc -l) -gt 1 ]; then
      printf '%s: %s\n' $filename >>$_FILE.multiple
      printf '%s' "$_matched_files" | sed -e 's/^/\t/' >>$_FILE.multiple
      printf '\n' >>$_FILE.multiple
    else
      printf '%s: %s\n' "$filename" "$_matched_files" >>$_FILE.single
    fi
  done <$_FILE.unique
}

_media_2010_check() {
  while read file; do
    if [ ! -e $file ]; then
      echo "$file does not exist"
    fi
  done <~/Desktop/2010.organize
}

_media_remove_underscores() {
  for file in $(grep '_' ~/Desktop/media.links); do
    new_file=$(printf '%s' "$file" | tr '_' '-')
    mkdir -p $(dirname "$new_file")

    mv -n "$file" "$new_file"
    git annex add "$new_file"
  done
}

_media_extension() {
  for file in $(grep '.jpeg$' ~/Desktop/media.links); do
    new_file=$(printf '%s' "$file" | sed -e 's/\.jpeg$/\.jpg/')
    mkdir -p $(dirname "$new_file")

    mv -n "$file" "$new_file"
    git annex add "$new_file"
  done
}

_media_extension
