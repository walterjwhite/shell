#!/bin/sh

lib sudo.sh

_DEVICE=$(sysctl kern.disks | sed -e "s/^.*://" | tr ' ' '\n' | grep -v "^$" | grep -v ada)
_DEVICES=$(printf '%s' $_DEVICE | wc -l)

if [ $_DEVICES -ne 1 ]; then
  exit_with_error "more than 1 device detected, aborting: $_DEVICE ($_DEVICES)" 1
fi

_MEDIA_VOLUME=$(zfs list | grep media$ | awk {'print$1'})
if [ -z $_MEDIA_VOLUME ]; then
  exit_with_error "media volume not found" 2
fi

_MEDIA_DEVICE=$(zpool status $_MEDIA_VOLUME | grep ONLINE | head -1 | awk {'print$1'})
if [ -z $_MEDIA_DEVICE ]; then
  exit_with_error "media device not found" 3
fi

sudo_ensure_root "$@"

_wait_until_resilvered() {
  while [ $(zpool status $_MEDIA_VOLUME | grep -c "action: Wait for the resilver") -eq 1 ]; do
    log_debug "sleeping $conf_media_management_zfs_pool_status_interval - waiting for $_DEVICE to resilver"

    sleep $conf_media_management_zfs_pool_status_interval
  done
}

log_info "unlocking $_DEVICE"
geli attach -p -k _DEVICE_KEY_PATH _DEVICE

log_info "onlining $_DEVICE into $_MEDIA_VOLUME"
zpool online $_MEDIA_VOLUME $_MEDIA_DEVICE ${_DEVICE}.elip1

_wait_until_resilvered

log_info "offlining $_DEVICE into $_MEDIA_VOLUME"
zpool offline ${_DEVICE}.elip1

log_info "locking $_DEVICE"
geli detach ${_DEVICE}

log_info "completed synchronization for $_DEVICE - safe to remove"
