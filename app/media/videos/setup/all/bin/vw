#!/bin/sh

lib io/path.sh
lib ./videos.sh

cfg git

_action=watch
: ${_OPTN_DISABLE_LONG_RUNNING_CMD_NOTIFICATION:=1}

_watch() {
  video_key=$(basename $video_media_file | $GNU_GREP -Po "\-{0,1}[0-9A-Za-z_-]{10}[048AEIMQUYcgkosw]\." | tail -1 | sed -e "s/^\-//" -e "s/\.$//" -e "s/\-/\\\-/g")
  video_file=$(grep $video_key downloaded -rl)

  if [ -z "$video_file" ]; then
    exit_with_error "downloaded video not found for: $video_key" 2
  fi

  _video_read_meta
  _video_meta

  _play
  _comments

  _move_watched_video
}

_play() {
  $conf_videos_video_player $_OPTN_VIDEOS_ARGUMENTS $video_media_file 2>&1 >/dev/null
}

_comments() {
  _stdin_read_if "Please enter comments (or hit enter for none)" _COMMENTS

  if [ -n "$_COMMENTS" ]; then
    printf '\n' >>$video_file
    printf '%s\n' "$_COMMENTS" >>$video_file
  fi
}

_move_watched_video() {
  _stdin_read_if "Retain video?" _RETAIN "N/y"

  if [ "$_RETAIN" = "y" ]; then
    _videos_git $video_file
  else
    video_watched_file=watched/$(_videos_date)

    rm -f $video_media_file

    _path_remove_empty_directories $conf_videos_download_path

    mkdir -p $(dirname $video_watched_file)

    git mv $video_file $video_watched_file

    _videos_git $video_file $video_watched_file
  fi
}

_watch_specified() {
  video_file=$1

  if [ ! -e $video_file ]; then
    video_media_file=$(find $conf_videos_download_path -type f ! -name '.part' | grep $video_file)
  fi

  if [ -z "$video_media_file" ]; then
    return 1
  fi

  _watch
}

_watch_clipboard() {
  _videos_clipboard_get

  if [ -n "$videos_url" ]; then
    video_key=$(printf '%s' $videos_url | sed -e "s/^.*\=//")
    if [ -n "$video_key" ]; then
      _clipboard_clear

      _watch_specified $video_key
      return $?
    fi
  fi

  return 1
}

_watch_all() {
  for video_media_file in $(find $conf_videos_download_path -type f ! -name '*.part'); do
    _watch
  done
}

_data_app_init
if [ "$#" -eq "1" ]; then
  _watch_specified $1
else
  _watch_clipboard || _watch_all
fi
