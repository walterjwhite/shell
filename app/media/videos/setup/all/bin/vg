#!/bin/sh

lib ./videos.sh

cfg git

sudo_ensure_not_root

_data_app_init
for video_file in $(find downloaded -type f); do
  _video_read_meta
  _video_meta

  [ -n "$extract_audio" ] && {
    unset videos_url video_key video_date video_duration video_title video_uploader_id video_uploader_name extract_audio video_profiles
    continue
  }

  log_info "$videos_url - $video_title @ $video_duration ($video_date:$video_uploader_id:$video_uploader_name)"
  unset videos_url video_key video_date video_duration video_title video_uploader_id video_uploader_name extract_audio video_profiles
done
