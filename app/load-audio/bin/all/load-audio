#!/bin/sh

_DEVICE_MOUNT_POINT=/mnt/$_APPLICATION_NAME

_load_audio_cleanup() {
	$_SUDO_CMD umount $_DEVICE_MOUNT_POINT
}

$_SUDO_CMD mkdir -p $_DEVICE_MOUNT_POINT
$_SUDO_CMD $_CONF_LOAD_AUDIO_MOUNT_COMMAND /dev/$_CONF_LOAD_AUDIO_MOUNT_DEVICE $_DEVICE_MOUNT_POINT || _ERROR "Error mounting $_CONF_LOAD_AUDIO_MOUNT_DEVICE via $_CONF_LOAD_AUDIO_MOUNT_COMMAND"

_defer _load_audio_cleanup

df -h /dev/$_CONF_LOAD_AUDIO_MOUNT_DEVICE

_INFO "Beginning copy: $_CONF_LOAD_AUDIO_SOURCE_DIRECTORY"
find $_CONF_LOAD_AUDIO_SOURCE_DIRECTORY -type f -name "*.$_CONF_LOAD_AUDIO_FORMAT" -exec $_SUDO_CMD cp {} $_DEVICE_MOUNT_POINT \; || _ERROR "Error copying files"

if [ $_CONF_LOAD_AUDIO_DELETE_ON_COPY -eq 1 ]; then
	_WARN "Deleting files: $_CONF_LOAD_AUDIO_SOURCE_DIRECTORY"
	find $_CONF_LOAD_AUDIO_SOURCE_DIRECTORY -type f -name "*.$_CONF_LOAD_AUDIO_FORMAT" -delete
else
	_WARN "Retaining files: $_CONF_LOAD_AUDIO_SOURCE_DIRECTORY"
fi

_success "Successfully copied files, please disconnect device"
