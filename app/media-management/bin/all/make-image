#!/bin/sh

for _ARG in $@; do
	case $_ARG in
	-l=*)
		_LABEL=
		;;
	-i=*)
		_INDEX=
		;;
	-f=*)
		_FILES=
		;;
	esac
done

if [ -z "$_INDEX" ]; then
	_ERROR "Disc index is required." 1
fi

if [ -z "$_LABEL" ]; then
	_ERROR "Disc label is required." 2
fi

if [ -z "$_FILES" ]; then
	_ERROR "Files is required." 3
fi

_INDEX=$1
shift

_OUTPUT_FILE=$_IMAGE_PATH/disc.$_INDEX.iso

mkisofs $_CDRECORD_OPTIONS -V $_LABEL -o $_OUTPUT_FILE $_FILES
