#!/bin/sh

lib io/file.sh
lib sudo.sh

_media_management_minidlna_restart() {
	_sudo rm -rf $_CONF_MEDIA_MANAGEMENT_MINIDLNA_DB

	_sudo service minidlna onerestart
}

if [ $# -lt 1 ]; then
	_ERROR "Expecting at least 1 media dir"
fi

_sudo $_CONF_GNU_SED -i '/^media_dir/d' $_CONF_MEDIA_MANAGEMENT_MINIDLNA_CONF

for media_dir in "$@"; do
	_require_file "$media_dir"
	_require "$_CONF_MEDIA_MANAGEMENT_MINIDLNA_CONF" _CONF_MEDIA_MANAGEMENT_MINIDLNA_CONF

	printf 'media_dir=%s\n' "$media_dir" | _append -a $_CONF_MEDIA_MANAGEMENT_MINIDLNA_CONF >/dev/null
done

_media_management_minidlna_restart
