#!/bin/sh

_online() {
	_INFO "Onlining $_CONF_MEDIA_MANAGEMENT_USB_DEVICE"
	_ $_SUDO_CMD geli attach -p -k $_CONF_MEDIA_MANAGEMENT_ENCRYPTION_KEY_FILE $_CONF_MEDIA_MANAGEMENT_USB_DEVICE
	_ $_SUDO_CMD zpool online $_CONF_MEDIA_MANAGEMENT_POOL $_EXISTING_DEVICE $_CONF_MEDIA_MANAGEMENT_USB_DEVICE.eli

	_INFO "Onlined $_CONF_MEDIA_MANAGEMENT_USB_DEVICE"
}

_offline() {
	_INFO "Offlining $_CONF_MEDIA_MANAGEMENT_USB_DEVICE"
	_ $_SUDO_CMD zpool offline $_CONF_MEDIA_MANAGEMENT_POOL $_CONF_MEDIA_MANAGEMENT_USB_DEVICE.eli
	_ $_SUDO_CMD zpool export $_CONF_MEDIA_MANAGEMENT_POOL
	_ $_SUDO_CMD geli detach $_CONF_MEDIA_MANAGEMENT_USB_DEVICE.eli
	_INFO "Offlined $_CONF_MEDIA_MANAGEMENT_USB_DEVICE"
}

_wait_for_resilver() {
	while [ $(zpool status $_CONF_POOL | $_CONF_GNU_GREP -Pc 'scan: resilver in progress') -gt 0 ]; do
		local resilver_status=$(zpool status $_CONF_POOL | grep scan: -A2 | tr '\n' ',' | sed -e 's/scan: //' -e 's/  //' -e 's/,$//')
		_INFO "Resilver in progress: $resilver_status"
		sleep $_CONF_MEDIA_MANAGEMENT_RESILVER_WAIT
	done

	_INFO "Resilver complete"
}

_EXISTING_DEVICE=$(zpool status $_CONF_MEDIA_MANAGEMENT_POOL | grep ONLINE | grep ada | awk {'print$1'})

if [ $(zpool status $_CONF_MEDIA_MANAGEMENT_POOL | $_CONF_GNU_GREP -P "[\t ]+$_CONF_MEDIA_MANAGEMENT_USB_DEVICE" | grep -c ONLINE) -eq 0 ]; then
	_online
else
	_WARN "$_CONF_MEDIA_MANAGEMENT_USB_DEVICE appears to already be online in $_CONF_MEDIA_MANAGEMENT_POOL"
fi

_wait_for_resilver
_offline
