#!/bin/sh

lib ./add.sh
lib git/data.app.sh

cfg git

_data_app_init

_append() {
  if [ -n "$_awk_match" ]; then
    _awk_match="$_awk_match && \$$1$2"
  else
    _awk_match="\$$1$2"
  fi
}


_aggregation=sum
_units=miles

group_bucket="sum += \$4; n++"
group_print="print $_aggregation\" \"units"

[ "$bike" ] && _append 3 "==\"$bike\""
[ "$start" ] && {
  _date=${start#*=}
  _add_validate_date
  _start_filter=$(printf '%s' "$_date" | sed -e "s/\///g")
  _append 1 ">=$_start_filter"
}
[ "$end" ] && {
  _date=${end#*=}
  _add_validate_date
  _end_filter=$(printf '%s' "$_date" | sed -e "s/\///g")
  _append 1 "<=$_end_filter"
}
[ "$group" ] && {
  case $group in
  bike)
    group_bucket="bucket = \$3;A[bucket] = A[bucket] + \$4;"

    ;;
  year)
    group_bucket="bucket = substr(\$1, 1, 4);A[bucket] = A[bucket] + \$4;"
    ;;
  month)
    group_bucket="bucket = substr(\$1, 1, 7);A[bucket] = A[bucket] + \$4;"
    ;;
  day)
    group_bucket="bucket = substr(\$1, 1, 7);A[bucket] = A[bucket] + \$4;"
    ;;
  esac

  group_print="for (i in A) {print i, A[i];}"
}

ride_filter=$(printf '%s {%s} END {%s}\n' "$_awk_match" "$group_bucket" "$group_print")

awk -F'|' "$ride_filter" \
  $(find $git_project_path -type f -name '*.csv') |
  sed -e "s/$/ $_units/" |
  sort
