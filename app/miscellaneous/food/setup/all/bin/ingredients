#!/bin/sh

readonly REQUIRED_ARGUMENTS="_ACTION:Action to perform (list,scale,unique,units,shopping)"

lib .

log_info "$(basename $PWD | sed -e 's/-/ /g')"

case $_ACTION in
list | scale | unique | units | shopping)
  ${_ACTION}_ingredients "$@"
  ;;
*)
  exit_with_error "unknown action: $_ACTION"
  ;;
esac
