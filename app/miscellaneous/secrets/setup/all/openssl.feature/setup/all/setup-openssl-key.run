#!/bin/sh

_secrets_openssl_initialize_key() {
  log_warn 'generating random key to use with openssl'
  dd if=/dev/random bs=32 count=1 of=$conf_secrets_openssl_key
}

if [ -e $conf_secrets_openssl_key ]; then
  log_detail "$conf_secrets_openssl_key already exists, not generating"
else
  _secrets_openssl_initialize_key
fi
