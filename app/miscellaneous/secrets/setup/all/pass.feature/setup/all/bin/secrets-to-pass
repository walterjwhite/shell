#!/bin/sh

for secret_key in $(secrets find /); do
  log_detail "migrating $secret_key"
  secret_value=$(secrets -out=stdout get $secret_key)


  export secret_key=$secret_key
  export secret_value=$secret_value

  __LIBRARY_PATH__/__APPLICATION_NAME__/secrets/walterjwhite/secret-pass.expect

  unset secret_key secret_value
done
