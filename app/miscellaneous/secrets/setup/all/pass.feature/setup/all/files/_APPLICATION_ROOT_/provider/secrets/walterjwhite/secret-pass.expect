#!/usr/bin/env expect

set timeout 1

log_user 0

spawn pass insert $env(secret_key)

expect {
    "Enter password for $env(secret_key):" {
        send $env(secret_value)\r
    }

    timeout {
        exit 1
    }
}

expect {
    "Retype password for $env(secret_key):" {
        send $env(secret_value)\r
    }

    timeout {
        exit 2
    }
}

expect {
    eof {
        exit 0
    }

    timeout {
        exit 3
    }
}
