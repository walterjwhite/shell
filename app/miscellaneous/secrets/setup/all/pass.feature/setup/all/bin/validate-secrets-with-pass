#!/bin/sh

for secret_key in $(secrets find /); do
  log_detail "validating $secret_key"

  secret_value=$(secrets -out=stdout get $secret_key)

  pass_value=$(pass show $secret_key)

  if [ "$secret_value" != "$pass_value" ]; then
    log_warn "$secret_key (secret / pass) do not match"
  fi
done

unset secret_key secret_value pass_value
