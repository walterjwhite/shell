[ $(secrets find email | wc -l) -gt 10 ] && log_info "success - secrets find email"
[ $(secrets find password | wc -l) -gt 10 ] && log_info "success - secrets find password"

[ $(secrets find email | grep -c email) -gt 0 ] && log_info "success - secrets find password, contains email in key"
[ $(secrets find password | grep -c password) -gt 0 ] && log_info "success - secrets find password, contains password in key"
