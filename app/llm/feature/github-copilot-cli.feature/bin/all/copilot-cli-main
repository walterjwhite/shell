#!/bin/sh

lib io/file.sh

_copilot_session_init() {
	_COPILOT_OPTIONS="${_COPILOT_OPTIONS--no-color}"
	_COPILOT_WORK_DIR=$(mktemp -d /tmp/copilot-cli-XXXXXX)
	_COPILOT_SESSION_DIR=$PWD

	git checkout -b "copilot-run-$RANDOM"

	_defer _copilot_cleanup
}

_copilot_cleanup() {
	rm -rf $_COPILOT_WORK_DIR
}

_copilot_file() {
	cd $_COPILOT_SESSION_DIR
	rm -rf $_COPILOT_WORK_DIR/ && mkdir -p $_COPILOT_WORK_DIR

	cp $f $_COPILOT_WORK_DIR

	cd $_COPILOT_WORK_DIR
	copilot-cli $PROMPT_NAME

	cp $_COPILOT_WORK_DIR/* $_COPILOT_SESSION_DIR/$(dirname $f)

	cd $_COPILOT_SESSION_DIR

	build || {
		_WARN "Build failed after applying copilot prompt $PROMPT_NAME to file $f"

		_COPILOT_FAILURES=$((_COPILOT_FAILURES + 1))

		git diff >/tmp/copilot-failure-$(date +%s).patch
		mkdir -p $_CONF_APPLICATION_DATA_PATH/copilot/
		mv /tmp/copilot-failure-*.patch $_CONF_APPLICATION_DATA_PATH/copilot/

		git reset --hard HEAD
		return 1
	}

	_DETAIL "Successfully applied copilot prompt $PROMPT_NAME to file $f"

	git add .
	git commit -am "copilot - $PTROMPT_NAME applied to $f"
}

_copilot_run() {
	for PROMPT in $(find $_CONF_APPLICATION_LIBRARY_PATH/prompts/ -type f); do
		PROMPT_NAME=$(basename $PROMPT)
		_DETAIL "Using prompt: $PROMPT_NAME from $PROMPT"

		for f in $(find . -type f); do
			_DETAIL "Processing file: $f"
			_copilot_file
		done
	done
}

_copilot_session_init
_copilot_run

if [ $_COPILOT_FAILURES -gt 0 ]; then
	_ERROR "Copilot session completed with $_COPILOT_FAILURES failures."
	exit 1
else
	_SUCCESS "Copilot session completed successfully with no failures."
fi
