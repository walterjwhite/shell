#!/bin/sh

_REQUIRED_ARGUMENTS="TIME_SUCCESS_CMD:CMD to evaluate before running primary cmd|TEST_SUCCESS_EVERY:Test success every|EXECUTION_CMD:CMD and any arguments to execute"

lib ./delay.sh

_time_delay_duration $_TIME_DELAY
allowed_iterations=$_TIME_ITERATIONS

while :; do
	$TIME_SUCCESS_CMD && {
		_INFO "success cmd completed successfully"
		break
	}

	_time_delay_duration $TEST_SUCCESS_EVERY

	[ -n "$_TIME_ITERATIONS" ] && {
		_TIME_ITERATIONS=$(($_TIME_ITERATIONS - 1))
		[ $_TIME_ITERATIONS -eq 0 ] && _ERROR "failed after $allowed_iterations tries"
	}
done

$_TIME_EXECUTE
