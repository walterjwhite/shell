#!/bin/sh

lib ./gh.auth.sh
lib sed.sh

_CONF_GITHUB_RESTORE_PATH=/projects

_github_restore() {
	local local_project_name=$(printf '%s' "$_PROJECT" | sed -e 's/_/\//g' -e 's/-$//')
	local local_project=$_CONF_GITHUB_RESTORE_PATH/$local_project_name.git
	mkdir -p $(dirname $local_project)

	git clone --mirror git@github.com:$_CONF_GITHUB_GIT_USER/$_PROJECT.git $local_project
}

_github_auth

mkdir -p $_CONF_GITHUB_RESTORE_PATH

_GIT_PROJECT_SED_SAFE=$(_sed_safe $_CONF_GITHUB_GIT_PROJECTS_PATH)
for _PROJECT in $(gh repo list -L 1000 | awk {'print$1'} | cut -f2 -d'/'); do
	_github_restore

done
