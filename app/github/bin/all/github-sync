#!/bin/sh

lib ./iterate.sh
lib ./pattern-matcher.sh
lib ./stage.github.project.sh
lib ./sync.project.contents.sh


_github_iterate() {
	_github_sync


	_ git add .

	(_github_review && _github_stage_changes) || _github_cleanup_staged
}

_github_iterate_init() {
	if [ -e .github.sync.ignore ]; then
		_WARN "Skipping $_APPLICATION_CMD of $_GIT_PROJECT"
	else
		_github_init
	fi
}

_github_iterate_main
