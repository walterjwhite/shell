#!/bin/sh

lib git/project.directory.sh
lib io/file.sh
lib ./iterate.sh

_github_iterate() {
	[ -z "$_GIT_NO_INIT_PROJECT_DIRECTORY" ] && _get_project_directory
	_GITHUB_PROJECT=$_PROJECT

	_INFO "Pushing $_GITHUB_PROJECT"

	cd $_CONF_APPLICATION_DATA_PATH
	cd $_GITHUB_PROJECT
	_require_file .git

	gcommit -am "$_CONF_GITHUB_COMMIT_MESSAGE"

	if [ -n "$_CONF_GITHUB_COMIT_TIME" ]; then
		_GIT_COMMIT_DATE_TIME=$(git log -1 --pretty=format:'%ci' | sed -E "s/[0-9]{2}:[0-9]{2}:[0-9]{2}/$_CONF_GITHUB_COMIT_TIME/")
		gad "$_GIT_COMMIT_DATE_TIME"
	fi

	if [ -n "$_OPTN_GITHUB_FIXUP_ROOT" ]; then
		_COMMITS_TO_SQUASH=$(gl | grep ^commit | wc -l)
		_COMMITS_TO_SQUASH=$((_COMMITS_TO_SQUASH - 1))

		gf $_COMMITS_TO_SQUASH -m="$_CONF_GITHUB_COMMIT_MESSAGE"

		_GITHUB_PUSH_OPTIONS="--force"
	fi


	gpush origin $_CONF_GITHUB_TARGET_BRANCH $_GITHUB_PUSH_OPTIONS

	cd ..
	rm -Rf $_GITHUB_PROJECT
}

_github_iterate_init() {
	:
}

_require_file $_CONF_APPLICATION_DATA_PATH
_github_iterate_main
