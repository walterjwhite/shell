#!/bin/sh

_REQUIRED_ARGUMENTS="_SECRETS_ACTION:delete get put generate find value-grep"

lib .
lib clipboard.sh

cfg qr

case $_SECRETS_ACTION in
delete | put)
	[ $# -lt 1 ] && _print_help_and_exit
	;;
get | find | value-grep | unlock | check | generate | last-changed) ;;
generate-wifi-ssid)
	_SECRETS_ACTION=generate

	_CONF_SECRETS_GENERATE_SYMBOLS=0

	[ "$_CONF_SECRETS_PASSWORD_LENGTH" -eq "32" ] && _CONF_SECRETS_PASSWORD_LENGTH=8
	;;
generate-wifi-key)
	_SECRETS_ACTION=generate
	_OPTN_SECRETS_REMOVE_SYMBOLS=":;\""

	[ "$_CONF_SECRETS_PASSWORD_LENGTH" -eq "32" ] && _CONF_SECRETS_PASSWORD_LENGTH=63
	;;
*)
	_ERROR "Invalid action: $_SECRETS_ACTION"
	;;
esac

[ -z "$_SECRETS_QUIET" ] && _INFO "$_SECRETS_ACTION $*"
_SECRETS_ACTION_FUNCTION=$(printf '%s' $_SECRETS_ACTION | tr '[[:lower:]]' '[[:upper:]]')
_call _SECRETS_$_SECRETS_ACTION_FUNCTION "$@" || . $_CONF_APPLICATION_LIBRARY_PATH/provider/$_CONF_SECRETS_PROVIDER/$_SECRETS_ACTION.sh
