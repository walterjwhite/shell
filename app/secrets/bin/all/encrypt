#!/bin/sh

_REQUIRED_ARGUMENTS="_ENCRYPTION_SOURCE_FILE:File to encrypt / decrypt"

lib ./decrypt.sh
lib ./encrypt.sh
lib io/file.sh

cfg qr

_require_file "$_ENCRYPTION_SOURCE_FILE"

case "$_ENCRYPTION_SOURCE_FILE" in
*.asc | *.gpg)
	_ENCRYPTION_ACTION=DECRYPT
	;;
*)
	_ENCRYPTION_ACTION=ENCRYPT
	;;
esac

_SECRETS_$_ENCRYPTION_ACTION
