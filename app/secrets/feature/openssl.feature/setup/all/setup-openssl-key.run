#!/bin/sh

_secrets_openssl_initialize_key() {
  _WARN 'Generating random key to use with openssl'
  dd if=/dev/random bs=32 count=1 of=/tmp/.data

  _sudo mv /tmp/.data $_CONF_SECRETS_OPENSSL_KEY
}

[ -e $_CONF_SECRETS_OPENSSL_KEY ] && {
  _success "$_CONF_SECRETS_OPENSSL_KEY already exists, not generating"
}

_secrets_openssl_initialize_key
