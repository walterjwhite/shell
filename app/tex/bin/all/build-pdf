#!/bin/sh

_tex_build() {
	rm -f *.pdf
	texi2pdf *.tex || _ERROR "Error generating PDF"
}

_tex_cleanup() {
	rm -f *.aux *.log *.out
}

_tex_version_pdf() {
	for f in $(ls *.pdf); do
		_GIT_REV=$(git rev-parse --short HEAD)
		mv $f $(printf '%s' $f | sed -e "s/\.pdf/-$_GIT_REV.pdf/")
	done
}

_defer _tex_cleanup
_tex_build && _tex_version_pdf
