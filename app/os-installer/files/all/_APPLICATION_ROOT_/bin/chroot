#!/bin/sh

lib ./chroot
lib io/write.sh
lib ./run.sh

OS_INSTALLER_CHROOT=1

_chroot_init
_configure

[ -z "$container" ] && _start_ssh

_hostname
_run _system

_ORIGINAL_LOGFILE=$_LOGFILE

_patches download file

_system_patches

_run_parallel

_patches package_uninstall package

_run_parallel_wait

_patches group user
_patches app go npm rust pypi
_patches link
_patches chown chmod run crontab
_patches service fstab cups_printer
_patches sysctl post_run

_PRESERVE_LOG=1 _set_logfile $_ORIGINAL_LOGFILE
[ -z "$container" ] && _stop_ssh
