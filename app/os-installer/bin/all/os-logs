#!/bin/sh

lib ./bootstrap

_read_logs() {
	for f in $($1); do
		less --redraw-on-quit $f
	done
}

_find_bootstrap_logs() {
	find $(dirname $_LOGFILE) $_CONF_OS_INSTALLER_MOUNTPOINT/var/log -type f -name 'os-installer-*.log' | sort -V
}

_find_chroot_logs() {
	find $_CONF_OS_INSTALLER_MOUNTPOINT/var/log/walterjwhite -type f | sort -V
}

_select_disk
_init_disk_encryption_get_device
_open_disk_encryption
_zpool_import
_zfs_mount
_setup_disks_efi
_mounts

_reset_logging

_read_logs _find_bootstrap_logs
_read_logs _find_chroot_logs
