#!/bin/sh

: ${_CONF_WEATHER_REPORT_MAX_AGE:=3600}
: ${_CONF_WEATHER_VERSION:=2}

if [ $# -gt 0 ]; then
	_LOCATION=$1
	shift
else
	_LOCATION=default
fi


if [ "$_CONF_WEATHER_VERSION" = "2" ]; then
	_WEATHER_URL=v2.wttr.in
else
	_WEATHER_URL=wttr.in
fi

_WEATHER_REPORT_FILE=$_CONF_APPLICATION_DATA_PATH/$_LOCATION.$_CONF_WEATHER_VERSION
mkdir -p $(dirname $_WEATHER_REPORT_FILE)

_weather_fetch() {
	curl -s http://$_WEATHER_URL -o $_WEATHER_REPORT_FILE

	touch $_WEATHER_REPORT_FILE
}

if [ -e $_WEATHER_REPORT_FILE ]; then
	_WEATHER_REPORT_CREATION_TIME=$(stat -s $_WEATHER_REPORT_FILE | tr ' ' '\n' | grep st_ctime | sed -e 's/.*=//')
	_NOW=$(date +%s)

	_WEATHER_REPORT_EXPIRATION_TIME=$(($_WEATHER_REPORT_CREATION_TIME + $_CONF_WEATHER_REPORT_MAX_AGE))

	if [ $_WEATHER_REPORT_EXPIRATION_TIME -lt $_NOW ]; then
		_weather_fetch
	fi
else
	_weather_fetch
fi

cat $_WEATHER_REPORT_FILE
