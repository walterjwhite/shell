#!/bin/sh

_REQUIRED_ARGUMENTS="_ACTION:The action to perform"

lib .
lib sed.sh

_ACTION=$(printf '%s' $_ACTION | tr '[:lower:]' '[:upper:]')

case $_ACTION in
archive | get | list | set | unarchive | comment | comments | summary)
	_CONSOLE_${_ACTION} "$@"
	;;
*)
	_ERROR "Unrecognized action: $_ACTION"
	;;
esac
