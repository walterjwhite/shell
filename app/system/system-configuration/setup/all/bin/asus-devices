#!/bin/sh

if [ $# -lt 1 ]; then
  exit_with_error "unique device identifier is required (Asus Router IP)"
fi

_asus_router_ip=$1
shift

_asus_device_activity() {
  if [ ! -e /var/log/messages ]; then
    return 1
  fi

  local devices=$(grep $_asus_router_ip /var/log/messages/log |
    $GNU_GREP -Poi '[0-9a-f]{2}:[0-9a-f]{2}:[0-9a-f]{2}:[0-9a-f]{2}:[0-9a-f]{2}:[0-9a-f]{2}' |
    tr '[:lower:]' '[:upper:]' | sort -u)

  local device
  for device in $devices; do
    grep $_asus_router_ip /var/log/messages/log |
      grep -i $device
  done
}

_asus_device_activity
