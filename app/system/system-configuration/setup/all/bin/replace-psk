#!/bin/sh


for _client_device_file in $(grep -l psk $_sorted_devices); do
  _type=$(basename $(dirname $_client_device_file) | tr '.' '\n' | tail -1)
  . /usr/local/etc/walterjwhite/system-configuration/types/$_type

  _new_psk=$(pwgen -s $psk_length 1)

  $GNU_SED -i "s/^psk=.*/psk=$_new_psk/" $_client_device_file

  unset psk_length
done
