#!/bin/sh

if [ $# -lt 1 ]; then
  exit_with_error "unique device identifier is required (IP, MAC)"
fi

_device_id=$1
shift

_device_id=$(printf '%s\n' "$_device_id" | tr '[:upper:]' '[:lower:]')

_device() {
  local type
  printf $_device_id | $GNU_GREP -iPcs '[0-9a-f]{2}\:[0-9a-f]{2}\:[0-9a-f]{2}\:[0-9a-f]{2}\:[0-9a-f]{2}\:[0-9a-f]{2}' >/dev/null 2>&1 && {
    type=mac
    _device_id=$(printf '%s\n' "$_device_id" | tr ':' '.')
  }

  printf $_device_id | $GNU_GREP -iPcs '[0-9a-f]{2}\.[0-9a-f]{2}\.[0-9a-f]{2}\.[0-9a-f]{2}\.[0-9a-f]{2}\.[0-9a-f]{2}' >/dev/null 2>&1 && type=mac

  if [ -z "$_mac" ]; then
    _device_id=$(grep $_device_id /etc/ethers | awk {'print$1'} | tr ':' '.')
  fi

  _device_conf=$(find /usr/local/etc/walterjwhite/system-configuration/devices -type f -name $_device_id ! -name '.*')
  _device_ip=$(grep _ip= $_device_conf | sed -e 's/^_ip=//')
  _device_hostname=$(grep _hostname= $_device_conf | sed -e 's/^_hostname=//')

  log_info "activity for: $_device_id | $_device_conf | $_device_hostname | $_device_ip"
}

_wifi_activity() {
  if [ ! -e /var/log/messages ]; then
    return 1
  fi

  {
    cat /var/log/messages/log
    zstdcat /var/log/messages/log*.zst
  } | awk /$_device_id/ | awk '{print$1" "$2" "$3" " $9" "$5" "$7}' | sed -e 's/:$//' |
    less
}

_isc_dhcpd_activity() {
  if [ ! -e /var/log/dhcpd ]; then
    return 1
  fi

  {
    cat /var/log/dhcpd/log
    zstdcat /var/log/dhcpd/log*.zst
  } | awk /$_device_id/ | awk '{print$1" "$2" "$3" " $7" "$9" "$11}' |
    sed -e 's/DHCPACK/ACK/g' -e 's/DHCPREQUEST/REQ/g' -e 's/DHCPDISCOVER/DIS/g' -e 's/DHCPOFFER/OFF/g' |
    less
}

_dnsmasq_activity() {
  if [ ! -e /var/log/dnsmasq ]; then
    return 1
  fi

  {
    cat /var/log/dnsmasq/log
    zstdcat /var/log/dnsmasq/log*.zst
  } | awk /$_device_id/ | awk '{print$1" "$2" "$3" " $6" "$7" "$8}' | grep DHCP |
    sed -e 's/DHCPACK/ACK/g' -e 's/DHCPREQUEST/REQ/g' -e 's/DHCPDISCOVER/DIS/g' -e 's/DHCPOFFER/OFF/g' | less

  device_ip=$(cat /var/log/dnsmasq/log | awk /$_device_id/ | awk {'print$7'} | head -1)
  if [ -z "$device_ip" ]; then
    device_ip=$(zstdcat /var/log/dnsmasq/log*.zst | awk /$_device_id/ | awk {'print$7'} | head -1)
  fi

  {
    cat /var/log/dnsmasq/log
    zstdcat /var/log/dnsmasq/log*.zst
  } | awk /$device_ip/ | grep -v DHCP | awk '{print$1" "$2" "$3" " $5" "$6}' | less
}

_device
_wifi_activity
_isc_dhcpd_activity
_dnsmasq_activity
