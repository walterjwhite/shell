#!/bin/sh

readonly REQUIRED_ARGUMENTS="_last_sequence_file:Last sequence file"

lib alert.sh
lib feature:apply-patches.sh
lib feature:update-system/create-be.sh
lib feature:update-system/patch.sh
lib jail.sh
lib ./network.sh
lib system-alert.sh

cfg feature:.

unset log_logfile

for SYSTEM_UPDATE in "$@"; do
  _PATCH_${SYSTEM_UPDATE}
  [ -n "$_check_restart" ] && _checkrestart

  unset _check_restart
done

date >>$_last_sequence_file
_reboot

system=$_logging_context _system_alert "Applied $* patches"
exit_with_success "Applied $* patches"
