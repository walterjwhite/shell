#!/bin/sh

cfg feature:

for _CONSOLE in $(find __LIBRARY_PATH__/__APPLICATION_NAME__/shell -mindepth 1 -maxdepth 1 -type d); do
  printf 'export LESSOPEN="| %s %s"\n' "$conf_console_source_highlight" '%s' > $_CONSOLE/source-highlight-less
  printf 'export LESS=" -R "\n' >> $_CONSOLE/source-highlight-less
done
