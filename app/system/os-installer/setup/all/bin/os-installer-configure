#!/bin/sh

lib ./bootstrap
lib ./chroot
lib io/write.sh
lib ./run.sh

cfg .
cfg git


sudo_ensure_root "$@"

log_info "configuring $APP_PLATFORM_PLATFORM $(uname -r) [$APPLICATION_VERSION]"

log_detail "snapshotting root volume"
zfs snapshot $(zfs list -o name,mountpoint | grep ' /$' | awk {'print$1'})@$(date +%Y.%m.%d-%H.%M.%S)

_remove_status
_init_net

conf_os_installer_mountpoint=/
_run_init

_setup_git
_validate_conf

_run_run _write_system
_mount_sshfs_cache
exit_defer _cleanup_processes


log_info "configuring booted system"
cd $conf_os_installer_system_workspace

_chroot_init
_configure_configure

[ -z "$_in_container" ] && _start_ssh

_hostname_hostname
_chroot_timezone

_run_run _system_main
_original_log_file=$log_logfile

_patches_patches download file

_system_patches

_run_parallel

_patches_patches package_uninstall package

_run_parallel_wait

_patches_patches group user
_patches_patches app go npm rust pypi
_patches_patches link
_patches_patches chown chmod run crontab
_patches_patches service fstab cups_printer
_patches_patches sysctl post_run

[ -n "$_updatedb_cmd" ] && $_updatedb_cmd

log_set_logfile $_original_log_file
[ -z "$_in_container" ] && _stop_ssh

_post_install
