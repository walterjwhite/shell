#!/bin/sh

readonly REQUIRED_ARGUMENTS="target_host:target Host (IP / FQDN)"

lib ./remote.sh

cfg .

sudo_ensure_root "$target_host" "$@"


tar cp -C ~/ .config/walterjwhite .ssh \
  $APP_PLATFORM_BIN_PATH/app-install |
  ssh $target_host "tar xp"

ssh $target_host 'mkdir -p $(dirname $PLATFORM_SYSTEM_ID_PATH) && printf "%s\n" > $PLATFORM_SYSTEM_ID_PATH' $conf_os_installer_system_name

ssh $target_host "$HOME/$BIN_PATH/app-install install os-installer"

_os_installer_prepare_remote
