#!/bin/sh

lib ./add.sh
lib git/data.app.sh

cfg git

_git_init

if [ "$#" -lt "4" ]; then
	_ERROR "Date, Index, Bike, and Distance are required (tags are optional)" 1
fi

_DATE=$(printf '%s' $1 | sed -e "s/\///g")
_INDEX=$2
_BIKE=$3
_DISTANCE=$4
_TAGS=$5

_DISTANCE=$(printf "%s *0.6213712\n" $_DISTANCE | bc)
_DISTANCE=$(printf "%.2f" "$_DISTANCE")

case $_DISTANCE in
*.00)
	_DISTANCE="${_DISTANCE%.00}"
	;;
*.*0)
	_DISTANCE=$(printf '%s' $_DISTANCE | sed -e 's/0$//')
	;;
esac

_file
_exists

printf '%s|%s|%s|%s|%s\n' "$_DATE" "$_INDEX" "$_BIKE" "$_DISTANCE" "$_TAGS" >>$_FILE

_git_save "add - $_DECADE/$_DATE,$_INDEX,$_BIKE" $_FILE
