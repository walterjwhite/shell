#!/bin/sh

lib ./ip-block
lib net/firewall.sh

mkdir -p /usr/local/etc/walterjwhite/network/ip-blocks
for ip_block_provider in $_CONF_FIREWALL_IP_BLOCK_PROVIDERS; do
	firewall_ip_block_${ip_block_provider}

	_has_contents $FIREWALL_PROVIDER_TEMP_FILE || {
		_WARN "Updating ${ip_block_provider} IP blocks failed"
		rm -f $FIREWALL_PROVIDER_TEMP_FILE
		continue
	}

	rm -f /usr/local/etc/walterjwhite/network/ip-blocks/${ip_block_provider}
	sort -u $FIREWALL_PROVIDER_TEMP_FILE >/usr/local/etc/walterjwhite/network/ip-blocks/${ip_block_provider}
	_firewall_update_table_from_file /usr/local/etc/walterjwhite/network/ip-blocks/${ip_block_provider} ip_blocks_${ip_block_provider}
done
