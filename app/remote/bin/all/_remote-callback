#!/bin/sh

_REQUIRED_ARGUMENTS="_FUNCTION_CALL:Function to call"

lib .
lib exec.sh


_set_logfile /var/log/walterjwhite/remote

_INFO "$_FUNCTION_CALL $*"

_call $_FUNCTION_CALL "$@" || {
	function_exit_status=$?
	[ $function_exit_status -eq 255 ] && _ERROR "$_FUNCTION_CALL undefined: 255" 255

	_ERROR "$_FUNCTION_CALL returned: $function_exit_status" $function_exit_status
}
