#!/bin/sh

lib ./die.sh
lib net/network.sh

_network_check() {
	_online && _success "Connected to Internet"

	_WARN "Unable to establish network connection"
	_WARN "powering off"

	[ -n "$_OPTN_REMOTE_SIMULATE_POWEROFF" ] && _ERROR "simulating poweroff"

	_die
}

_restrict_to_single_process

_network_check
