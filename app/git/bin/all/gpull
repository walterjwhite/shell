#!/bin/sh

lib git/include.sh

if [ -z "$_GIT_RECURSIVE" ]; then
	_git_in_working_directory || {
		_GIT_RECURSIVE=1
		find . \( -type d -or -type f \) -and -name '.git' -execdir gpull "$@" \;

		exit
	}
fi

_git_relative_path
_INFO "$_PROJECT_RELATIVE_PATH"

git_remotes=$(git remote | wc -l)
if [ $git_remotes -ne 1 ] && [ $# -eq 0 ]; then
	_ERROR 'Please specify remote to pull'
fi

git pull "$@"
