#!/bin/sh

_REQUIRED_ARGUMENTS="_GIT_SINCE:SHA1 Hash of starting commit or date"

lib git/project.directory.sh

_get_project_directory

_git_is_hash() {
	printf '%s\n' "$1" | $_CONF_GNU_GREP -Pq '([\da-f]{8}|[\da-f]{32})'
}

_git_rev_list() {
	git rev-list ${_GIT_SINCE}..${_TARGET_REVISION}
}

_git_commits_since() {
	git log --format=%H --since="$_GIT_SINCE"
}

_git_is_hash $_GIT_SINCE && _git_rev_list ||
	_git_commits_since
