---
#
#

services:
  sandbox:
    build:
      context: .
      dockerfile: Dockerfile.wolfi
    image: dev-sandbox:latest
    stdin_open: true
    tty: true
    volumes:
      - ${INPUT_DIR:-./input}:/input:ro,Z

      - kiro-config:/root/.kiro:Z
      - codex-config:/root/.codex:Z
      - copilot-config:/root/.config/github-copilot:Z
      - gemini-config:/root/.gemini:Z
      - qwen-config:/root/.qwen:Z
      - npm-global:/root/.npm:Z

      - gradle-cache:/root/.gradle:Z
      - maven-cache:/root/.m2:Z
      - android-cache:/root/.android:Z


    environment:
      - OPENAI_API_KEY=${OPENAI_API_KEY:-}
      - GH_TOKEN=${GH_TOKEN:-}
      - GITHUB_TOKEN=${GITHUB_TOKEN:-}
      - GEMINI_API_KEY=${GEMINI_API_KEY:-}
      - DASHSCOPE_API_KEY=${DASHSCOPE_API_KEY:-}
      - AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID:-}
      - AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY:-}
      - AWS_DEFAULT_REGION=${AWS_DEFAULT_REGION:-us-east-1}
      - ANDROID_HOME=/opt/android-sdk
      - ANDROID_SDK_ROOT=/opt/android-sdk

    working_dir: /workspace

volumes:
  kiro-config:
  codex-config:
  copilot-config:
  gemini-config:
  qwen-config:
  npm-global:
  gradle-cache:
  maven-cache:
  android-cache:
