#!/bin/sh

lib ./logging.sh
lib ./run.sh

_dev_run_do() {
	_LANGUAGE=$_APPLICATION_TYPE
	_setup_log
	_application_runner "$@"
	exit $?
}

[ ! -e .application ] && _ERROR ".application does not exist, unable to run" 1

[ $_DEV_CLEAR_LOG ] && rm -rf .log
[ $_DEV_TYPES ] && {
	for _APPLICATION_TYPE in $_DEV_TYPES; do
		_dev_run_do
	done
}

for _APPLICATION_TYPE in $(ls .application); do
	_dev_run_do
done
