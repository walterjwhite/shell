#!/bin/sh

lib git/include.sh
lib git/project.directory.sh

cfg feature:.

_project_directory_get_project_directory || exit_with_error "not in a git workspace"
_git_relative_path

cd $git_project_path

. $conf_dev_detect_secrets_venv/bin/activate

conf_dev_detect_secrets_report_path=$APP_DATA_PATH/detect_secrets/$git_project_relative_path/$(gcb).json
mkdir -p $(dirname $conf_dev_detect_secrets_report_path)

if [ ! -e $conf_dev_detect_secrets_report_path ]; then
  eval "detect-secrets scan $conf_dev_detect_secrets_exclude_files" >$conf_dev_detect_secrets_report_path
else
  eval "detect-secrets scan --baseline $conf_dev_detect_secrets_report_path $conf_dev_detect_secrets_exclude_files"
fi

if [ $(jq '[.results[][] | select(.is_verified == false)] | length' "$conf_dev_detect_secrets_report_path") -gt 0 ]; then
  log_warn "detect-secrets - auditing repository for secrets - $conf_dev_detect_secrets_report_path"
  detect-secrets audit $conf_dev_detect_secrets_report_path
else
  log_info "detect-secrets - no findings"
fi
