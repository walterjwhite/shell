lib net/download.sh
lib extract.sh

_TRIVY_VERSION=0.48.2
_download_fetch https://github.com/aquasecurity/trivy/releases/download/v$_TRIVY_VERSION/trivy_${_TRIVY_VERSION}_FreeBSD-64bit.tar.gz

mkdir /tmp/trivy
_extract_extract $download_file /tmp/trivy
sudo_run mv /tmp/trivy/trivy $BIN_PATH

rm -rf /tmp/trivy
