#!/bin/sh

lib git/project.directory.sh
lib scan/report.sh

_gitleaks_cleanup() {
  rm -f "$gitleaks_new_report"
}

_project_directory_get_project_directory
_git_relative_path

cd $git_project_path

gitleaks_project_report_path=$APP_DATA_PATH/gitleaks/$git_project_relative_path/$(gcb).json
mkdir -p $(dirname $gitleaks_project_report_path)

[ -e $gitleaks_project_report_path ] && gitleaks_args="-b $_GITLEAKS_PROJECT_REPORT_PATH"

gitleaks_new_report=$(_mktemp_mktemp)
gitleaks_args="$_GITLEAKSargS -r $gitleaks_new_report"

exit_defer _gitleaks_cleanup
gitleaks detect -v --no-banner --no-color $gitleaks_args >/dev/null 2>&1 || _review_scan_report "gitleaks" "$gitleaks_new_report" "$gitleaks_project_report_path"
