#!/bin/sh

readonly REQUIRED_ARGUMENTS="git_url:The git url of the project to clone"

lib git/include.sh
lib system.sh

cfg git



_git_restore_user_data() {
  project_relative_path=$(basename $git_url)
  project_full_path=$DATA_PATH/$project_relative_path
}

_git_restore_project() {
  case $git_url in
  *@* | *://*)
    project_relative_path=${git_url%.git}
    project_relative_path=${project_relative_path#*@*:}
    project_relative_path=${project_relative_path#*://}
    project_relative_path=${project_relative_path#*/}
    ;;
  *)
    project_relative_path=${git_url%.git}

    [ -n "$optn_git_mirror" ] && {
      project_mirror_host=$optn_git_mirror
      project_mirror_host=${project_mirror_host#*@}
      project_mirror_host=${project_mirror_host%:*}
      project_mirror_host=${project_mirror_host#*://}
      project_mirror_host=${project_mirror_host%%/*}

      project_relative_path=$project_mirror_host/$project_relative_path
      git_url=$optn_git_mirror/$git_url
    }
    ;;
  esac

  project_full_path=$GIT_PROJECT_BASE_PATH/$project_relative_path
}

case $git_url in
*data/*)
  case $git_url in
  */$USER/*)
    _git_restore_user_data
    ;;
  *)
    log_warn "restoring under projects"
    _git_restore_project
    ;;
  esac

  [ -n "$optn_git_mirror" ] && {
    git_url=$optn_git_mirror/$git_url
  }
  ;;
*)
  _git_restore_project
  ;;
esac

log_detail "cloning $git_url into $project_full_path"
git clone $git_url "$@" $project_full_path

printf '%s\n' "$project_full_path"
