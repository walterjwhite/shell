#!/bin/sh

lib ./delete-date.sh
lib git/delete.sh
lib git/include.sh


_git_backup_cleanup() {
  if [ -z "$repository_has_deleted_branches" ]; then
    log_warn "no branches were deleted, dropping backup file"
    rm -rf $repository_clone_file
  fi
}

if [ -z "$git_recursive" ]; then
  _git_in_working_directory || {
    export git_recursive=1
    find . \( -type d -or -type f \) -and -name '.git' -execdir gdob "$@" \;

    exit
  }
fi

exit_defer _git_backup_cleanup

_delete_date=$(_git_delete_date)
validation_require "$_delete_date" _DELETE_DATE
log_info "archiving/deleting old branches - $PWD"

gpull

_git_create_backup_mirror
_git_delete_branches
