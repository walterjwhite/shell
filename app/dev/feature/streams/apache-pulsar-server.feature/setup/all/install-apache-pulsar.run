#!/bin/sh

lib net/download.sh

_APACHE_PULSAR_VERSION=4.1.2
_APACHE_PULSAR_INSTALL_PATH=/opt/apache/pulsar

_download "https://www.apache.org/dyn/closer.lua/pulsar/pulsar-$_APACHE_PULSAR_VERSION/apache-pulsar-$_APACHE_PULSAR_VERSION-bin.tar.gz?action=download"

_CLEAN=$_APACHE_PULSAR_INSTALL_PATH _SUDO_REQUIRED=1 _extract "$_DOWNLOADED_FILE" "$_APACHE_PULSAR_INSTALL_PATH"

