#!/bin/sh

_REQUIRED_ARGUMENTS="SHELL_FILE_TO_FMT:Shell file to format"

_sh_app_fmt_cleanup() {
	rm -f $SH_APP_FMT_OUT_FILE
}

SH_APP_FMT_OUT_FILE=$(mktemp)
_defer _sh_app_fmt_cleanup


grep '^#!/bin/sh' $SHELL_FILE_TO_FMT >>$SH_APP_FMT_OUT_FILE
grep -cqm1 '^#!/bin/sh' $SHELL_FILE_TO_FMT && printf '\n' >>$SH_APP_FMT_OUT_FILE

grep '^_REQUIRED_ARGUMENTS=' $SHELL_FILE_TO_FMT >>$SH_APP_FMT_OUT_FILE
grep -cqm1 '^_REQUIRED_ARGUMENTS=' $SHELL_FILE_TO_FMT && printf '\n' >>$SH_APP_FMT_OUT_FILE

grep '^lib ' $SHELL_FILE_TO_FMT | sort -k 2 >>$SH_APP_FMT_OUT_FILE
grep -cqm1 '^lib ' $SHELL_FILE_TO_FMT && printf '\n' >>$SH_APP_FMT_OUT_FILE

grep '^cfg ' $SHELL_FILE_TO_FMT | sort -k 2 >>$SH_APP_FMT_OUT_FILE
grep -cqm1 '^cfg ' $SHELL_FILE_TO_FMT && printf '\n' >>$SH_APP_FMT_OUT_FILE

grep '^init ' $SHELL_FILE_TO_FMT | sort -k 2 >>$SH_APP_FMT_OUT_FILE
grep -cqm1 '^init ' $SHELL_FILE_TO_FMT && printf '\n' >>$SH_APP_FMT_OUT_FILE

grep -Pv '^(lib |cfg |init |#!/bin/sh|_REQUIRED_ARGUMENTS=)' $SHELL_FILE_TO_FMT >>$SH_APP_FMT_OUT_FILE

chmod --reference=$SHELL_FILE_TO_FMT $SH_APP_FMT_OUT_FILE
mv $SH_APP_FMT_OUT_FILE $SHELL_FILE_TO_FMT

sed -i '/^$/N;/\n$/D' $SHELL_FILE_TO_FMT
