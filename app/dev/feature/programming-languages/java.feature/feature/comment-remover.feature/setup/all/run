#!/bin/sh

lib net/download.sh
cfg feature:.

_COMMENT_REMOVER_JAR_URL=https://repo1.maven.org/maven2/$_CONF_DEV_COMMENT_REMOVER_GROUP/$_CONF_DEV_COMMENT_REMOVER_ARTIFACT/${_CONF_DEV_COMMENT_REMOVER_VERSION}/$_CONF_DEV_COMMENT_REMOVER_JAR_FILENAME

_download $_COMMENT_REMOVER_JAR_URL
_download_install_file $_CONF_DEV_COMMENT_REMOVER_JAR
