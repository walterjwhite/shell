#!/bin/sh

lib ./auth.sh

cfg .

conf_github_restore_path=/projects

_github_restore() {
  local local_project_name=$(printf '%s' "$_PROJECT" | sed -e 's/_/\//g' -e 's/-$//')
  local local_project=$conf_github_restore_path/$local_project_name.git
  mkdir -p $(dirname $local_project)

  git clone --mirror git@github.com:$conf_github_git_user/$_PROJECT.git $local_project
}

_github_auth

mkdir -p $conf_github_restore_path
for _PROJECT in $(gh repo list -L 1000 | awk {'print$1'} | cut -f2 -d'/'); do
  _github_restore

done
