#!/bin/sh

readonly REQUIRED_ARGUMENTS="_FROM_PACKAGE:From Package|_TO_PACKAGE:To Package"

find . -type f \( ! -path '*/.git/*' ! -path '*/target/*' \) -exec $GNU_SED -i "s/$_FROM_PACKAGE/$_TO_PACKAGE/" {} +

from_package_path=$(printf '%s' "$_FROM_PACKAGE" | tr '.' '/')
to_package_path=$(printf '%s' "$_TO_PACKAGE" | tr '.' '/')
for from_java_package in $(find . -type d -path '*/src/*' -path "*/$from_package_path"); do
  to_java_package=$(printf '%s' "$from_java_package" | sed -e "s|^$from_package_path|$to_package_path|")

  mkdir -p $(dirname $to_java_package)
  mv $from_java_package $to_java_package
done
