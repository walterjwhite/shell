#!/bin/sh

if [ $# -gt 0 ]; then
  if [ $1 = "init" ]; then
    spring_cli_args="-x"
  fi
fi

feature_name=SPRING
java -cp __LIBRARY_PATH__/__APPLICATION_NAME__/tools/feature/$feature_name/spring-boot-cli.jar org.springframework.boot.loader.JarLauncher "$@" "$spring_cli_args" || exit_with_error "see above exit_with_error message"

git init
git add .
gcommit -am 'spring init'
