#!/bin/sh

lib net/download.sh
cfg feature:.


_download_fetch https://repo1.maven.org/maven2/com/google/googlejavaformat/google-java-format/${conf_dev_google_java_format_version}/google-java-format-${conf_dev_google_java_format_version}-all-deps.jar
_download_install_file $conf_dev_google_java_format_jar
