name: build
on: push
jobs:
  build:
    runs-on: ${{ matrix.runner }}
    strategy:
      matrix:
        include:
          - { runner: ubuntu-latest, os: linux,   arch: amd64 }
    steps:
      - uses: actions/checkout@v3
      - name: build
        run: |
          printf 'FreeBSD Linux Apple Windows\n' > supported-platforms
          /bin/sh build
