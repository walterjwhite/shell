#!/bin/sh

_REQUIRED_ARGUMENTS="REMOTE_SERVER_IP:IP Address of the remote server to connect to"

_restrict_to_single_process
_stunnel_client_ip

_stunnel_firewall_cleanup
_stunnel_firewall_update && _defer _stunnel_firewall_cleanup

_stunnel_firewall_wait_conf

_stunnel_client_update_conf

if [ $# -gt 0 ]; then
	for STUNNEL_TARGET in "$@"; do
		_STUNNEL_CLIENT_RUN_${STUNNEL_TARGET}
	done
else
	_STUNNEL_CLIENT_RUN_WEB
fi

_stunnel_client_wait
